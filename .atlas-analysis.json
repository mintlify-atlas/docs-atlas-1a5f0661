  "keyFeatures": [
    "Cross-platform styling for React and React Native with 100% parity",
    "Optimizing compiler that flattens styled components to atomic CSS",
    "40+ production-ready UI components with full accessibility support",
    "Powerful theming system with tokens and variants",
    "Multiple animation drivers (CSS, React Native, Reanimated, Motion)",
    "Framework integrations for Next.js, Vite, Expo, Metro, and Webpack",
    "CLI tools for scaffolding and theme generation",
    "TypeScript-first with full type safety"
  ],
  "publicApiSurface": [
    "styled() - Create styled components",
    "createTamagui() - Configure Tamagui instance",
    "createComponent() - Create base components",
    "createTokens() - Define design tokens",
    "createTheme() - Create theme objects",
    "View, Text, Stack, YStack, XStack - Layout primitives",
    "Button, Input, Select, Dialog, Sheet - UI components",
    "useTheme() - Access theme values",
    "useMedia() - Responsive media queries",
    "Theme - Theme provider component",
    "@tamagui/vite-plugin - Vite compiler integration",
    "@tamagui/next-plugin - Next.js compiler integration",
    "@tamagui/cli - Command-line interface",
    "TamaguiProvider - Root provider component"
  ]
